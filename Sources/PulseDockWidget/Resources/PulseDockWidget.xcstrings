  "strings" : {
    "widget.description" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Show Mac CPU, memory, disk, connection, power, load, thermal, uptime, system, and kernel status on your desktop."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在桌面显示 Mac 的 CPU、内存、磁盘、连接、电源、负载、热状态、运行时间、系统和内核状态。"
          }
        }
      }
    },
